# Claude Code Plugin — jadlis-research
# IMPORTANT: .gitignore is created FIRST to prevent API key leaks

# =============================================================================
# MCP Config — .mcp.json is committed (uses ${VAR} refs, safe)
# =============================================================================
.mcp.json.local

# =============================================================================
# Plugin Runtime Data
# =============================================================================
.scratchpads/
.pubmed-search/
.arxiv-mcp-server/

# =============================================================================
# OS Junk
# =============================================================================
.DS_Store
.DS_Store?
Thumbs.db
._*

# =============================================================================
# Python Runtime
# =============================================================================
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
*.egg-info/
dist/
build/

# =============================================================================
# Node Runtime
# =============================================================================
node_modules/

# =============================================================================
# Temporary Files
# =============================================================================
*.tmp
tmp/

# =============================================================================
# Environment Variables
# =============================================================================
.env
.env.*

# =============================================================================
# Vendor Dependencies (cloned repos, not committed)
# =============================================================================
vendors/

# =============================================================================
# Local Settings (developer-specific, not for sharing)
# =============================================================================
*.local.md

# =============================================================================
# Setup Wizard Test Artifacts
# =============================================================================
$JADLIS_ENV_FILE
$JADLIS_HOME/
