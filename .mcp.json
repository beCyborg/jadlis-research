{
  "$schema": "https://raw.githubusercontent.com/anthropics/claude-code/main/schemas/mcp-config.schema.json",
  "mcpServers": {
    "semantic-scholar": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/akapet00/semantic-scholar-mcp",
        "semantic-scholar-mcp"
      ],
      "env": {
        "SEMANTIC_SCHOLAR_API_KEY": "${SEMANTIC_SCHOLAR_API_KEY}"
      }
    },
    "openalex": {
      "command": "npx",
      "args": [
        "-y",
        "openalex-research-mcp@0.3.0"
      ],
      "env": {
        "OPENALEX_EMAIL": "${OPENALEX_EMAIL}",
        "OPENALEX_API_KEY": "${OPENALEX_API_KEY}"
      }
    },
    "pubmed": {
      "command": "npx",
      "args": [
        "-y",
        "@cyanheads/pubmed-mcp-server@1.4.5"
      ],
      "env": {
        "NCBI_EMAIL": "${NCBI_EMAIL}",
        "NCBI_API_KEY": "${NCBI_API_KEY}"
      }
    },
    "arxiv": {
      "command": "uvx",
      "args": [
        "arxiv-mcp-server"
      ]
    },
    "crossref": {
      "command": "uvx",
      "args": [
        "crossref-cite-mcp"
      ],
      "env": {
        "CROSSREF_MAILTO": "${CROSSREF_MAILTO}"
      }
    },
    "paper-download": {
      "command": "uvx",
      "args": [
        "paper-download-mcp"
      ],
      "env": {
        "PAPER_DOWNLOAD_EMAIL": "${PAPER_DOWNLOAD_EMAIL}"
      }
    },
    "hn": {
      "command": "uvx",
      "args": [
        "mcp-hn"
      ]
    },
    "substack": {
      "command": "uv",
      "args": [
        "run",
        "--with",
        "git+https://github.com/dkyazzentwatwa/substack_mcp",
        "python",
        "-m",
        "substack_mcp.mcp_server"
      ]
    },
    "twitter": {
      "command": "uv",
      "args": [
        "run",
        "--directory",
        "${CLAUDE_PLUGIN_ROOT}/vendors/grok-mcp",
        "python",
        "main.py"
      ],
      "env": {
        "XAI_API_KEY": "${XAI_API_KEY}"
      }
    },
    "google-maps": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-google-maps@0.6.2"],
      "env": {
        "GOOGLE_MAPS_API_KEY": "${GOOGLE_MAPS_API_KEY}"
      }
    },
    "xpoz": {
      "type": "streamable-http",
      "url": "https://mcp.xpoz.ai/mcp"
    },
    "exa": {
      "command": "npx",
      "args": [
        "-y", "exa-mcp-server@3.1.8",
        "--tools=web_search_exa,web_search_advanced_exa,crawling_exa,company_research_exa,people_search_exa,get_code_context_exa,deep_researcher_start,deep_researcher_check"
      ],
      "env": {
        "EXA_API_KEY": "${EXA_API_KEY}"
      }
    },
    "firecrawl": {
      "command": "npx",
      "args": ["-y", "firecrawl-mcp@3.9.0"],
      "env": {
        "FIRECRAWL_API_KEY": "${FIRECRAWL_API_KEY}"
      }
    }
  }
}
